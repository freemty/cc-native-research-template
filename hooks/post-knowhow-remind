#!/bin/bash
# Hook: PostToolUse(Bash) — remind to archive environment knowledge
# Detects env-related commands (install, docker, ssh, debug errors) and suggests /update-knowhow

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/hook-utils"

INPUT=$(cat)

# Extract command (cheap — single jq)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null)
if [ -z "$COMMAND" ]; then exit 0; fi

# Skip trivial commands early (before extracting output — saves 2x jq)
if echo "$COMMAND" | grep -qE '^(ls|cat|head|tail|pwd|cd|echo|wc|file|which|type)( |$)|^git (log|status|diff|branch|show)( |$)'; then
  exit 0
fi

MATCHED=0

# Signal 1: environment config commands
if echo "$COMMAND" | grep -qiE '(apt(-get)? install|pip install|conda install|docker (build|run|pull|push|compose)|ssh |scp |rsync |mount |umount |systemctl |nvidia-smi|chmod |chown |curl -[oOL]|wget |export [A-Z]|source.*activate|nvm |pyenv |brew install)'; then
  MATCHED=1
fi

# Signal 2: error keywords in output (only extract output if signal 1 didn't match)
if [ "$MATCHED" -eq 0 ]; then
  OUTPUT=$(echo "$INPUT" | jq -r '.tool_output.stdout // empty' 2>/dev/null)
  STDERR=$(echo "$INPUT" | jq -r '.tool_output.stderr // empty' 2>/dev/null)
  COMBINED="$OUTPUT $STDERR"
  if echo "$COMBINED" | grep -qiE '\b(error|failed|permission denied|not found|no such file|connection refused|timeout|OOM|out of memory|segfault|killed|errno)\b|CUDA error'; then
    MATCHED=1
  fi
fi

if [ "$MATCHED" -eq 0 ]; then exit 0; fi

# Frequency control: 5 min apart
if [ "$(should_remind knowhow_remind 0.083)" != "yes" ]; then exit 0; fi

# Session count check + increment + mark reminded (single python3 call)
STATE_FILE=".labmate-hook-state.json"
ALLOWED=$(python3 -c "
import json
from datetime import datetime
f = '$STATE_FILE'
try:
    s = json.load(open(f))
except:
    s = {}
count = s.get('knowhow_session_count', 0)
if count >= 3:
    print('no')
else:
    s['knowhow_session_count'] = count + 1
    json.dump(s, open(f, 'w'), indent=2)
    print('yes')
" 2>/dev/null || echo "yes")

if [ "$ALLOWED" != "yes" ]; then exit 0; fi

mark_reminded knowhow_remind

cat << 'HINT'
<knowhow-hint>
刚才的操作看起来包含值得记录的环境知识。
要归档吗？说"记下来"或 /update-knowhow
</knowhow-hint>
HINT
