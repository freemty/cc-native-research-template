#!/usr/bin/env bash
# SessionStart hook for LabMate plugin
# Injects context based on project initialization state

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Detect project state
if [ ! -f ".pipeline-state.json" ]; then
    # Project not initialized — prompt to run /init-project
    context="<labmate>\n\nLabMate is active but this project has not been initialized yet.\n\nRun /init-project to set up experiment directories, CLAUDE.md, and pipeline state.\n\nAvailable now: @domain-expert @project-advisor @exp-manager @slides-maker\n\n</labmate>"
else
    # Project initialized — inject current state + workflow reminder
    current_exp=$(python3 -c "import json; print(json.load(open('.pipeline-state.json')).get('current_exp', 'null'))" 2>/dev/null || echo "null")
    stage=$(python3 -c "import json; print(json.load(open('.pipeline-state.json')).get('stage', 'dev'))" 2>/dev/null || echo "dev")

    context="<labmate>\n\nLabMate active. exp: ${current_exp} | stage: ${stage}\n\nWorkflow: /new-experiment -> /monitor -> /analyze-experiment -> /visualize -> /commit-changelog\n\nAgents: @domain-expert @project-advisor @exp-manager @slides-maker @viz-frontend\nSkills: /read-paper /survey-literature /new-experiment /analyze-experiment /visualize /monitor /commit-changelog /update-project-skill\n\nProject knowledge: .claude/skills/project-skill/SKILL.md\n\n</labmate>"
fi

# --- Periodic reminders (frequency-capped) ---
if [ -f ".pipeline-state.json" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  source "${SCRIPT_DIR}/hook-utils"

  reminders=""

  # Remind to read papers (7-day cap)
  if [ "$(should_remind 'read_paper' 168)" = "yes" ]; then
    days_since=$(python3 -c "
import os, glob
from datetime import datetime
papers = glob.glob('docs/papers/*.md')
papers = [p for p in papers if 'landscape' not in p]
if not papers:
    print('never')
else:
    latest = max(os.path.getmtime(p) for p in papers)
    days = (datetime.now().timestamp() - latest) / 86400
    print(int(days))
" 2>/dev/null || echo "never")
    if [ "$days_since" = "never" ]; then
      reminders="${reminders}No papers in docs/papers/ yet. Try /read-paper to start building your literature base.\n"
      mark_reminded "read_paper"
    elif [ "$days_since" -gt 7 ] 2>/dev/null; then
      reminders="${reminders}It's been ${days_since} days since your last paper note. Try /read-paper to stay current.\n"
      mark_reminded "read_paper"
    fi
  fi

  # Remind weekly progress (Friday+, 24h cap)
  DOW=$(date +%u)
  if [ "$DOW" -ge 5 ]; then
    WEEK=$(date +%Y-W%V)
    WEEKLY_FILE="docs/weekly/${WEEK}.md"
    if [ ! -f "$WEEKLY_FILE" ] && [ "$(should_remind 'weekly' 24)" = "yes" ]; then
      reminders="${reminders}No weekly progress for ${WEEK}. Run /commit-changelog --weekly to summarize this week.\n"
      mark_reminded "weekly"
    fi
  fi

  if [ -n "$reminders" ]; then
    context="${context}\n---\nReminders:\n${reminders}"
  fi
fi

escaped=$(escape_for_json "$context")

# Output context injection
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
    printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
fi

exit 0
